# Orthanc PACS
ORTHANC_URL=http://your-orthanc-host:8042
ORTHANC_USER=orthanc
ORTHANC_PASSWORD=your_password
ORTHANC_VERIFY_SSL=false        # false | true | /etc/ssl/certs/orthanc-ca.crt

# Поріг — дослідження старші N років будуть запропоновані до видалення
RETENTION_YEARS=5

# GLPI
GLPI_URL=http://your-glpi-host
GLPI_APP_TOKEN=your_app_token   # GLPI → Налаштування → Загальні → API
GLPI_USER_TOKEN=your_user_token # Профіль користувача → Зовнішній токен API
GLPI_VERIFY_SSL=false           # false | true | /etc/ssl/certs/glpi-ca.crt
GLPI_CATEGORY_ID=1              # ID категорії тікету
GLPI_ENTITY_ID=0                # ID організації (0 = root)
GLPI_ASSIGN_USER_ID=4           # ID відповідального

# Файли стану — мають бути унікальні для кожного сервера
STUDIES_FILE=/tmp/orthanc-cleanup/default/studies_to_delete.json
STATE_FILE=/tmp/orthanc-cleanup/default/state.json
